# ════════════════════════════════════════════════════════════════════════════
# Signal & Telegram Relay Configuration
# ════════════════════════════════════════════════════════════════════════════

# Signal Configuration
SIGNAL_WEB_PASSWORD=1111
SIGNAL_NUMBER=+420737500587
SIGNAL_API_URL=http://signal-api:8080

# Cloudflare Tunnel (optional - only enable for public access)
# Instructions:
# 1. Visit: https://dash.cloudflare.com/?to=/:account/networking/networks
# 2. Create a tunnel and copy the token
# 3. Paste below and run: docker compose --profile cloudflare up -d
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=signal-relay-tunnel
CLOUDFLARE_TUNNEL_HOSTNAME=signal-relay.tunnel.dev

# Telegram API Credentials (from reminder_config.json)
TELEGRAM_API_ID=38690162
TELEGRAM_API_HASH=238a5673793fc596ba2cf39be0678d93

# Docker Compose Metadata
COMPOSE_PROJECT_NAME=signal-relay
COMPOSE_PROFILES=

# Logging
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Dashboard Advanced Settings & Limits (consolidated)
# ──────────────────────────────────────────────────────────────────────────────
SIGNAL_GROUPS_FILE=groups.json
SIGNAL_ALLOWLIST_SHA256=
SIGNAL_STATE_FILE=.signal-sender-state.json
SIGNAL_STATE_SECRET_FILE=.signal-sender-secret
SIGNAL_LOCK_FILE=.signal-sender.lock

SIGNAL_MAX_GROUPS_PER_RUN=25
SIGNAL_MAX_MESSAGE_CHARS=10000
SIGNAL_MIN_INTERVAL_SECONDS=2
SIGNAL_DUPLICATE_WINDOW_SECONDS=3600
SIGNAL_PER_GROUP_COOLDOWN_SECONDS=5
SIGNAL_MAX_SENDS_PER_HOUR=100
SIGNAL_MAX_SENDS_PER_DAY=300
SIGNAL_REQUEST_TIMEOUT_SECONDS=30
SIGNAL_GET_MAX_RETRIES=2
