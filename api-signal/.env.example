# Номер Signal в международном формате.
SIGNAL_NUMBER=+420123456789

# Docker Compose service. Для запуска Python на host используйте
# http://127.0.0.1:8080 вместе с временным docker-compose.link.yml.
SIGNAL_API_URL=http://signal-api:8080
SIGNAL_WEB_PASSWORD=1111

SIGNAL_GROUPS_FILE=groups.json
# Заполните SHA-256 файла groups.json перед первой реальной отправкой.
SIGNAL_ALLOWLIST_SHA256=
SIGNAL_STATE_FILE=.signal-sender-state.json
SIGNAL_STATE_SECRET_FILE=.signal-sender-secret
SIGNAL_LOCK_FILE=.signal-sender.lock

# Защитные лимиты.
SIGNAL_MAX_GROUPS_PER_RUN=25
SIGNAL_MAX_MESSAGE_CHARS=10000
SIGNAL_MIN_INTERVAL_SECONDS=2
SIGNAL_DUPLICATE_WINDOW_SECONDS=3600
SIGNAL_PER_GROUP_COOLDOWN_SECONDS=5
SIGNAL_MAX_SENDS_PER_HOUR=100
SIGNAL_MAX_SENDS_PER_DAY=300
SIGNAL_REQUEST_TIMEOUT_SECONDS=30
SIGNAL_GET_MAX_RETRIES=2

# Telegram user-session sender.
# Получите api_id и api_hash на https://my.telegram.org.
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
TELEGRAM_PHONE=+420123456789
TELEGRAM_WEB_PASSWORD=1111
TELEGRAM_SESSION_FILE=.telegram.session
TELEGRAM_STATE_FILE=.telegram-sender-state.json
TELEGRAM_STATE_SECRET_FILE=.telegram-sender-secret
TELEGRAM_LOCK_FILE=.telegram-sender.lock

# Защитные лимиты Telegram.
TELEGRAM_MAX_CHATS_PER_RUN=25
TELEGRAM_MAX_MESSAGE_CHARS=4096
TELEGRAM_MIN_INTERVAL_SECONDS=2
TELEGRAM_DUPLICATE_WINDOW_SECONDS=3600
TELEGRAM_PER_CHAT_COOLDOWN_SECONDS=5
TELEGRAM_MAX_SENDS_PER_HOUR=100
TELEGRAM_MAX_SENDS_PER_DAY=300
